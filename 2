import random

nested_list = [[random.randint(1, 20) for _ in range(4)] for _ in range(3)]

print("Исходный вложенный список:")
for row in nested_list:
    print(row)

total_sum = 0
max_row_sum = float('-inf')
max_sum_row_index = -1

for i in range(len(nested_list)):
    current_row_sum = 0

    for j in range(len(nested_list[i])):
        current_row_sum += nested_list[i][j]

    print(f"Сумма элементов строки {i}: {current_row_sum}")

    total_sum += current_row_sum

    if current_row_sum > max_row_sum:
        max_row_sum = current_row_sum
        max_sum_row_index = i

print(f"Общая сумма всех элементов: {total_sum}")
print(f"Строка с максимальной суммой ({max_row_sum}): индекс {max_sum_row_index}")
