import random

nested_list = [[random.randint(1, 5) for _ in range(5)] for _ in range(4)]
target_value = random.randint(1, 5)

print(f"Ищем значение: {target_value}")
print("Исходный вложенный список:")
for row in nested_list:
    print(row)

found_positions = []

i = 0
while i < len(nested_list):
    j = 0
    while j < len(nested_list[i]):
        if nested_list[i][j] == target_value:
            found_positions.append((i, j))
        j += 1
    i += 1

print(f"\nРезультаты поиска для элемента {target_value}:")
if len(found_positions) > 0:
    for pos in found_positions:
        print(f"Найдено в позиции: строка {pos[0]+1}, элемент {pos[1]+1}")
else:
    print("Элемент не найден во вложенном списке.")
